# === Single-Tenant Mode (original) ===
# Set these to run LokiLens for one workspace with no database.

# Slack (create app at https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Gemini (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Loki
LOKI_BASE_URL=http://localhost:3100
LOKI_API_KEY=
LOKI_TIMEOUT=30s
LOKI_MAX_RETRIES=2

# Safety
MAX_TIME_RANGE=24h
MAX_RESULTS=500
RATE_LIMIT_PER_USER=20
RATE_LIMIT_BURST=5

# Server
HEALTH_ADDR=:8080

# Logging
LOG_LEVEL=info

# === Multi-Tenant Mode ===
# Set DATABASE_URL to enable multi-tenant mode. Workspaces are loaded from the
# database instead of env vars. All fields below are required in this mode.

# PostgreSQL (Neon)
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Encryption key for secrets at rest (32 bytes, hex-encoded = 64 chars)
# Generate with: openssl rand -hex 32
# ENCRYPTION_KEY=

# Shared Gemini key for free-tier workspaces (100 queries/day)
# GEMINI_SHARED_KEY=

# Slack OAuth (from your app's Basic Information page)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=

# Public URL for OAuth callbacks and Slack interactions
# BASE_URL=https://your-domain.com
